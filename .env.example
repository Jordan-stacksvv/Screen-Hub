# ─────────────────────────────────────────────────────────────
# ScreenHub — Self-Hosted Environment Configuration
# Copy to .env and fill with values from your own Supabase project.
# ─────────────────────────────────────────────────────────────

# Public (browser) — safe to expose. From: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Server (SSR / server functions / API routes)
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Server-only SECRET — never expose to the browser. Bypasses RLS.
# From: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional — only if you use Lovable AI Gateway features
# LOVABLE_API_KEY=""
